{
  "name": "Worklyn",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "android:dev": "react-native run-android --active-arch-only",
    "android:release": "react-native run-android --mode=release --active-arch-only",
    "gradle:debug": "cd android && ./gradlew :app:assembleDebug -PreactNativeArchitectures=arm64-v8a --parallel --build-cache",
    "gradle:release": "cd android && ./gradlew :app:assembleRelease -PreactNativeArchitectures=arm64-v8a --parallel --build-cache",
    "gradle:bundle": "cd android && ./gradlew :app:bundleRelease --parallel --build-cache",
    "android:clean:safe": "rm -rf android/app/.cxx android/app/build android/build",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-navigation/native": "^7.2.2",
    "lucide-react-native": "^1.14.0",
    "react": "19.2.3",
    "react-native": "0.85.2",
    "react-native-calendars": "^1.1314.0",
    "react-native-nitro-modules": "^0.35.6",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-svg": "^15.15.4",
    "react-native-unistyles": "^3.2.4"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.85.2",
    "@react-native/eslint-config": "0.85.2",
    "@react-native/jest-preset": "0.85.2",
    "@react-native/metro-config": "0.85.2",
    "@react-native/typescript-config": "0.85.2",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
